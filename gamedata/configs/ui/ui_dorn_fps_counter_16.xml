<hud>
	<!-- Positions set at runtime from HUD_LAYOUT in dorn_fps_counter_main.script -->
	<wnd x="0" y="0" width="240" height="70" stretch="1">
		<fps_simple x="0" y="0" width="60" height="22" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1"/>
		</fps_simple>
		<fps_lbl x="0" y="0" width="34" height="22" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1">FPS:</text>
		</fps_lbl>
		<fps_val x="0" y="0" width="44" height="22" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1"/>
		</fps_val>
		<min_lbl x="0" y="0" width="34" height="22" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1">Min:</text>
		</min_lbl>
		<min_val x="0" y="0" width="44" height="22" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1"/>
		</min_val>
		<max_lbl x="0" y="0" width="34" height="22" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1">Max:</text>
		</max_lbl>
