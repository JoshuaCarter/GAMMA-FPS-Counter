		<graph_max_val x="0" y="0" width="50" height="14" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1"/>
		</graph_max_val>
		<graph_fps_val x="0" y="0" width="50" height="14" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1"/>
		</graph_fps_val>
		<graph_min_val x="0" y="0" width="50" height="14" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1"/>
		</graph_min_val>
		<graph_root x="0" y="0" width="1" height="1" stretch="1"/>
		<graph_pixel x="0" y="0" width="1" height="1" stretch="1">
			<texture r="255" g="255" b="255" a="255">ui_inGame2_white_rect</texture>
		</graph_pixel>
	</wnd>
</hud>
