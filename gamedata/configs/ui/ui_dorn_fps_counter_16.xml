<hud>
	<!-- value column x=36 aligns numbers for proportional font; row step y=0/26/52 fits large font -->
	<wnd x="0" y="0" width="80" height="78" stretch="1">
		<fps_simple x="0" y="0" width="60" height="26" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1"/>
		</fps_simple>
		<fps_lbl x="0" y="0" width="34" height="26" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1">FPS:</text>
		</fps_lbl>
		<fps_val x="36" y="0" width="44" height="26" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1"/>
		</fps_val>
		<min_lbl x="0" y="26" width="34" height="26" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1">Min:</text>
		</min_lbl>
		<min_val x="36" y="26" width="44" height="26" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1"/>
		</min_val>
		<max_lbl x="0" y="52" width="34" height="26" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1">Max:</text>
		</max_lbl>
		<max_val x="36" y="52" width="44" height="26" stretch="1">
			<text font="letterica18" r="255" g="255" b="255" a="255" align="l" complex_mode="1"/>
		</max_val>
	</wnd>
</hud>
